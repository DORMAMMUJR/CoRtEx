generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  USER
  ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  FACEBOOK
}

enum CatalogItemType {
  PRODUCT
  TEXT
  IMAGE
  CTA
}

enum CatalogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PublicationVisibility {
  PUBLIC
  UNLISTED
  PROTECTED
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum AnalyticsEventType {
  VIEW
  CLICK
  DOWNLOAD
  SHARE
}

enum ApiKeyScope {
  CATALOG_READ
  CATALOG_WRITE
  ASSET_WRITE
  ANALYTICS_READ
  ADMIN_READ
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String?
  role          Role           @default(USER)
  fullName      String?
  avatarUrl     String?
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  profile       Profile?
  oauthAccounts OAuthAccount[]
  sessions      Session[]
  bookshelves   Bookshelf[]
  catalogs      Catalog[]
  subscriptions Subscription[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]     @relation("AuditActor")

  @@index([createdAt])
  @@index([role, createdAt])
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  companyName   String?
  phone         String?
  locale        String   @default("es-MX")
  timezone      String   @default("America/Mexico_City")
  darkTheme     Boolean  @default(true)
  glassmorphism Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt, revokedAt])
}

model Bookshelf {
  id          String    @id @default(cuid())
  userId      String
  name        String
  description String?
  slug        String
  color       String?
  position    Int       @default(0)
  isArchived  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  catalogs    Catalog[]

  @@unique([userId, slug])
  @@index([userId, position])
  @@index([userId, isArchived])
}

model Catalog {
  id              String           @id @default(cuid())
  userId          String
  bookshelfId     String?
  title           String
  slug            String
  description     String?
  coverImageUrl   String?
  sourcePdfUrl    String?
  status          CatalogStatus    @default(DRAFT)
  version         Int              @default(1)
  isArchived      Boolean          @default(false)
  publishedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookshelf       Bookshelf?       @relation(fields: [bookshelfId], references: [id], onDelete: SetNull)
  items           CatalogItem[]
  assets          Asset[]
  publication     Publication?
  analyticsEvents AnalyticsEvent[]

  @@unique([userId, slug])
  @@index([userId, status, createdAt])
  @@index([bookshelfId, createdAt])
}

model CatalogItem {
  id          String          @id @default(cuid())
  catalogId   String
  position    Int             @default(0)
  type        CatalogItemType
  name        String?
  description String?
  price       Decimal?        @db.Decimal(10, 2)
  currency    String          @default("MXN")
  imageUrl    String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  catalog     Catalog         @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  assets      Asset[]

  @@index([catalogId, position])
}

model Asset {
  id             String       @id @default(cuid())
  userId         String
  catalogId      String?
  catalogItemId  String?
  fileName       String
  mimeType       String
  sizeBytes      Int
  storagePath    String
  publicUrl      String?
  checksumSha256 String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  catalog        Catalog?     @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  catalogItem    CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([catalogId])
}

model Publication {
  id             String                @id @default(cuid())
  catalogId      String                @unique
  status         CatalogStatus         @default(DRAFT)
  visibility     PublicationVisibility @default(PUBLIC)
  publicSlug     String                @unique
  passwordHash   String?
  seoTitle       String?
  seoDescription String?
  socialImageUrl String?
  publishedAt    DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  catalog        Catalog               @relation(fields: [catalogId], references: [id], onDelete: Cascade)
  events         AnalyticsEvent[]

  @@index([status, visibility, publishedAt])
}

model AnalyticsEvent {
  id            String             @id @default(cuid())
  userId        String?
  catalogId     String?
  publicationId String?
  type          AnalyticsEventType
  sessionId     String?
  referer       String?
  country       String?
  city          String?
  userAgent     String?
  metadata      Json?
  createdAt     DateTime           @default(now())
  catalog       Catalog?           @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  publication   Publication?       @relation(fields: [publicationId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([publicationId, createdAt])
  @@index([catalogId, createdAt])
}

model Subscription {
  id                     String             @id @default(cuid())
  userId                 String
  tier                   SubscriptionTier   @default(FREE)
  status                 SubscriptionStatus @default(TRIALING)
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([tier, status])
}

model ApiKey {
  id         String        @id @default(cuid())
  userId     String
  name       String
  keyPrefix  String
  keyHash    String        @unique
  scopes     ApiKeyScope[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  action       String
  resourceType String
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([resourceType, createdAt])
  @@index([action, createdAt])
}
